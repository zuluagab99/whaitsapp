# --- Core ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://whaitsapp:whaitsapp@localhost:5432/whaitsapp
REDIS_URL=redis://localhost:6379

# --- Encryption (32-byte hex key for AES-256-GCM app-layer encryption of tokens) ---
# Generate with: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=

# --- Meta WhatsApp Cloud API ---
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v21.0

# --- Shopify ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_checkouts,write_draft_orders,read_inventory,read_fulfillments

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3000
