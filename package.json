{
  "name": "whaitsapp",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-tenant AI chatbot SaaS for WhatsApp + Shopify",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --filter './apps/**' run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev:api": "pnpm --filter @whaitsapp/api dev",
    "dev:worker": "pnpm --filter @whaitsapp/worker dev",
    "dev:dashboard": "pnpm --filter @whaitsapp/dashboard dev",
    "db:generate": "pnpm --filter @whaitsapp/db generate",
    "db:migrate": "pnpm --filter @whaitsapp/db migrate"
  }
}
